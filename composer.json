{
  "autoload": {
    "psr-4": {
      "Helpers\\": "Helpers/",
      "Src\\": "src/",
      "Config\\": "config/"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpmd/phpmd": "^2.15"
  },
  "require": {
    "vlucas/phpdotenv": "^5.6"
  },
  "scripts": {
    "phpstan": "phpstan analyse src config Helpers --level=10",
    "phpmd": "phpmd src config Helpers text cleancode,codesize,design,naming"
  }
}